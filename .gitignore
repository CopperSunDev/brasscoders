# Root-only — the un-scoped form was matching node_modules/<pkg>/lib/
# and silently truncating npm packages (notably @babel/parser/lib/),
# which broke CI when node_modules wasn't tracked but partial pieces
# of it were. Keep these anchored.
/lib/
/lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

