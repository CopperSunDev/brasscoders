*.tmp
*.temp
.cache/.brass_self_analysis/
test_deployment/.brass_test_results/
*.DS_Store

# Self-analysis output (running brassai on its own source)
.brass_self_analysis/

# Local triage notes (intentionally not version-controlled)
.brass-review-triage.md

# Dev scratchpads — debugging scripts and one-off QA reports
# accumulated during development. They live in the working tree but
# don't belong in the repo.
analyze_*.py
check_*.py
debug_*.py
final_integration_test.py
identify_potential_bugs.py
measure_tool_performance.py
new_failure_scenarios_analysis.py
production_readiness_test.py
