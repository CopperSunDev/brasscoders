[bandit]
# Exclude test directories and common non-production files
exclude = tests,examples,docs,scripts,.git,.tox,.eggs,__pycache__

# Skip test-specific security checks that are normal in test contexts
skips = B101,B108,B106,B602,B607

# Focus on production security issues only
tests = B102,B103,B104,B105,B107,B201,B301,B302,B303,B304,B305,B306,B307,B308,B309,B310,B311,B312,B313,B314,B315,B316,B317,B318,B319,B320,B321,B322,B323,B324,B325,B401,B402,B403,B404,B405,B406,B407,B408,B409,B410,B411,B412,B413,B501,B502,B503,B504,B505,B506,B507,B508,B509,B601,B603,B604,B605,B608,B609,B610,B611,B701,B702,B703

# B101 - assert_used: Skip for test files (normal usage)
# B108 - hardcoded_tmp_directory: Skip for test files (acceptable in tests)
# B106 - hardcoded_password_funcarg: Skip for test fixtures
# B602 - subprocess_popen_with_shell_equals_true: Skip for tests with controlled input
# B607 - start_process_with_partial_path: Skip for test utilities