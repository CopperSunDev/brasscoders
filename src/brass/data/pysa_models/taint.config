{
  "comment": "Brass-shipped Pysa taint configuration. Defines the universe of sources, sinks, and the rules that connect them. Customer projects inherit this via the PysaTaintScanner's staged .pyre_configuration.",
  "sources": [
    {
      "name": "UserControlled",
      "comment": "HTTP request data, CLI args, environment, or other attacker-influenced input"
    }
  ],
  "sinks": [
    {"name": "SQL",                "comment": "SQL execution sink"},
    {"name": "Shell",              "comment": "Shell command execution sink"},
    {"name": "RemoteCodeExecution","comment": "Arbitrary code execution sink (eval/exec/pickle/yaml.load)"},
    {"name": "SSRF",               "comment": "Outbound HTTP/URL fetch sink"},
    {"name": "Filesystem",         "comment": "File read/write/delete sink (path traversal)"},
    {"name": "XSS",                "comment": "Unescaped HTML output sink"}
  ],
  "features": [],
  "rules": [
    {
      "name": "SQL injection",
      "code": 5001,
      "sources": ["UserControlled"],
      "sinks":   ["SQL"],
      "message_format": "User-controlled input flows into SQL execution"
    },
    {
      "name": "Command injection",
      "code": 5002,
      "sources": ["UserControlled"],
      "sinks":   ["Shell"],
      "message_format": "User-controlled input flows into shell execution"
    },
    {
      "name": "Remote code execution",
      "code": 5003,
      "sources": ["UserControlled"],
      "sinks":   ["RemoteCodeExecution"],
      "message_format": "User-controlled input flows into an arbitrary-code sink (eval/exec/pickle/yaml.load)"
    },
    {
      "name": "SSRF",
      "code": 5004,
      "sources": ["UserControlled"],
      "sinks":   ["SSRF"],
      "message_format": "User-controlled input flows into an outbound URL fetch"
    },
    {
      "name": "Path traversal",
      "code": 5005,
      "sources": ["UserControlled"],
      "sinks":   ["Filesystem"],
      "message_format": "User-controlled input flows into a filesystem path"
    },
    {
      "name": "XSS",
      "code": 5006,
      "sources": ["UserControlled"],
      "sinks":   ["XSS"],
      "message_format": "User-controlled input flows into an HTML-rendering sink"
    }
  ]
}
